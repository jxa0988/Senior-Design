# === OAuth ===
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# === Django Core ===
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=1

# === Hosts & Domains (CRITICAL) ===
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000

# === CSRF (MANDATORY for Django 4+ HTTPS) ===
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:8080,https://app.com

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8080,https://app.com

# === Cookies / Security ===
COOKIE_DOMAIN=localhost

# === Database ===
DB_HOST=localhost
DB_NAME=roofvision
DB_USER=postgres
DB_PASS=your-database-password
DB_PORT=5432
DB_SSLMODE=prefer

# === Storage ===
BUCKET_NAME=roofimage-dev
